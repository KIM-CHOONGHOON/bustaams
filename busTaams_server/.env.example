# busTaams 서버 환경 변수 — 이 파일을 복사해 `.env` 로 저장한 뒤 값을 채웁니다.
# `cp .env.example .env`  (이름은 `busTaams_server` 기준)
#
# ⚠️ `.env` 는 Git에 커밋하지 마세요. 로컬 MySQL 기본 포트는 3306 입니다.

PORT=8080
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=bustaams

FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-admin-key.json

# AES-256-GCM (32 bytes hex)
ENCRYPTION_KEY=

# 공공데이터포털 API 키 (선택)
PUBLIC_DATA_SERVICE_KEY=
