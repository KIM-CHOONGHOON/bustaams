# ============================================================
# busTaams 프로젝트 루트 .gitignore
# 환경변수·비밀키·빌드 산출물을 GitHub 에서 완전히 제외한다.
# ============================================================

# ── 환경변수 파일 (절대 커밋 금지) ──────────────────────────
**/.env
**/.env.local
**/.env.*.local
**/.env.development
**/.env.production

# ── Firebase Admin 비공개 키 (절대 커밋 금지) ───────────────
**/firebase-admin-key.json
**/*-service-account*.json
**/*-credentials*.json

# ── 의존성 패키지 (용량 크고 재설치 가능) ───────────────────
**/node_modules/

# ── 프론트엔드 빌드 산출물 ──────────────────────────────────
busTaams_web/dist/
busTaams_admin/dist/

# ── 에디터 / OS 임시 파일 ───────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── 로그 파일 ───────────────────────────────────────────────
*.log
npm-debug.log*
